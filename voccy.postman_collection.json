{
	"info": {
		"name": "Voccy API",
		"description": "Feedback board API",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:6767"
		},
		{
			"key": "board_id",
			"value": ""
		},
		{
			"key": "feedback_id",
			"value": ""
		},
		{
			"key": "access_token",
			"value": ""
		},
		{
			"key": "refresh_token",
			"value": ""
		}
	],
	"item": [
		{
			"name": "Health",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"url": "{{base_url}}/health"
					}
				}
			]
		},
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"url": "{{base_url}}/auth/register",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Demo Org\",\n    \"email\": \"demo@example.com\",\n    \"password\": \"password123\"\n}"
						}
					}
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.data && jsonData.data.access_token) {",
									"    pm.collectionVariables.set('access_token', jsonData.data.access_token);",
									"}",
									"if (jsonData.data && jsonData.data.refresh_token) {",
									"    pm.collectionVariables.set('refresh_token', jsonData.data.refresh_token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"url": "{{base_url}}/auth/login",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"demo@example.com\",\n    \"password\": \"password123\"\n}"
						}
					}
				},
				{
					"name": "Refresh",
					"request": {
						"method": "POST",
						"url": "{{base_url}}/auth/refresh",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"refresh_token\": \"{{refresh_token}}\"\n}"
						}
					}
				},
				{
					"name": "Logout",
					"request": {
						"method": "DELETE",
						"url": "{{base_url}}/auth/logout"
					}
				}
			]
		},
		{
			"name": "Boards",
			"item": [
				{
					"name": "Create Board",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.data && jsonData.data.id) {",
									"    pm.collectionVariables.set('board_id', jsonData.data.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"url": "{{base_url}}/boards",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Product Feedback\",\n    \"description\": \"Collect user feedback for our product\",\n    \"settings\": {\n        \"allow_anonymous\": true,\n        \"require_email\": false,\n        \"max_feedback_length\": 2000,\n        \"voting_enabled\": true,\n        \"moderation\": \"none\"\n    }\n}"
						}
					}
				},
				{
					"name": "List Boards",
					"request": {
						"method": "GET",
						"url": "{{base_url}}/boards"
					}
				},
				{
					"name": "Get Board by ID",
					"request": {
						"method": "GET",
						"url": "{{base_url}}/boards/{{board_id}}"
					}
				},
				{
					"name": "Update Board",
					"request": {
						"method": "PUT",
						"url": "{{base_url}}/boards/{{board_id}}",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Product Feedback Updated\",\n    \"description\": \"Updated description\",\n    \"settings\": {\n        \"voting_enabled\": false,\n        \"moderation\": \"pre\"\n    }\n}"
						}
					}
				},
				{
					"name": "Delete Board",
					"request": {
						"method": "DELETE",
						"url": "{{base_url}}/boards/{{board_id}}",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							}
						]
					}
				}
			]
		},
		{
			"name": "Feedbacks",
			"item": [
				{
					"name": "Create Feedback",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.data && jsonData.data.id) {",
									"    pm.collectionVariables.set('feedback_id', jsonData.data.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"url": "{{base_url}}/boards/{{board_id}}/feedbacks",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Add dark mode\",\n    \"body\": \"It would be great to have a dark mode option for the dashboard\",\n    \"author_name\": \"John Doe\",\n    \"author_email\": \"john@example.com\"\n}"
						}
					}
				},
				{
					"name": "List Feedbacks by Board",
					"request": {
						"method": "GET",
						"url": "{{base_url}}/boards/{{board_id}}/feedbacks"
					}
				},
				{
					"name": "Get Feedback by ID",
					"request": {
						"method": "GET",
						"url": "{{base_url}}/boards/{{board_id}}/feedbacks/{{feedback_id}}"
					}
				},
				{
					"name": "Update Feedback Status",
					"request": {
						"method": "PATCH",
						"url": "{{base_url}}/boards/{{board_id}}/feedbacks/{{feedback_id}}",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"status\": \"in_progress\"\n}"
						}
					}
				},
				{
					"name": "Delete Feedback",
					"request": {
						"method": "DELETE",
						"url": "{{base_url}}/boards/{{board_id}}/feedbacks/{{feedback_id}}",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							}
						]
					}
				}
			]
		}
	]
}
